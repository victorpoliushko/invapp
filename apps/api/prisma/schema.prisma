generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EDITOR
  USER
}

model User {
  id                 String  @id @default(uuid())
  username           String  @unique
  password           String
  phoneNumber        String?
  email              String
  hashedRefreshToken String?
  role               Role    @default(USER)

  settings         UserSettings?
  portfolios       Portfolio[]
  investStrategies InvestStrategy[]

  // TODO
  // ApiKey ApiKey[]
}

model UserSettings {
  id              String   @id @default(uuid())
  receiveSMS      Boolean?
  publicPortfolio Boolean?

  user   User?  @relation(fields: [userId], references: [id])
  userId String @unique
}

// TODO: fix stock type that comes from CSV
enum AssetType {
  BOND
  CASH
  COMMODITY
  CRYPTOCURRENCY
  ETF
  MUTUALFUND
  PRECIOUS_METAL
  PRIVATE_EQUITY
  Stock
}

enum DataSource {
  ALPHA_VANTAGE
  COINGECKO
}

model Asset {
  id              String      @id @default(uuid())
  ticker          String      @unique
  name            String?
  type            AssetType?
  exchange        String?
  dataSource      DataSource?
  coingeckoId     String?
  updatedAt       DateTime?   @updatedAt
  currentPrice    Float?
  priceUpdatedAt  DateTime?

  portfolioAssets   PortfolioAsset[]
  // transactions Transaction[]
}

model Portfolio {
  id   String @id @default(uuid())
  name String
  goal Float?

  user   User?  @relation(fields: [userId], references: [id])
  userId String

  portfolioAssets  PortfolioAsset[]
  realEstateAssets RealEstate[]
  bonds            Bond[]
}

enum RealEstateType {
  APARTMENT
  HOUSE
  COMMERCIAL
}

model RealEstate {
  id            String         @id @default(uuid())
  code          String
  name          String
  type          RealEstateType
  purchaseDate  DateTime
  purchasePrice Float

  portfolio     Portfolio              @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  portfolioId   String
  transactions  RealEstateTransaction[]
}

model RealEstateTransaction {
  id           String     @id @default(uuid())
  startDate    DateTime
  endDate      DateTime
  monthlyRent  Float

  realEstate   RealEstate @relation(fields: [realEstateId], references: [id], onDelete: Cascade)
  realEstateId String
}

model PortfolioAsset {
  portfolioId String
  assetId     String

  quantity Float
  price    Float?

  portfolio    Portfolio     @relation(fields: [portfolioId], references: [id])
  asset        Asset         @relation(fields: [assetId], references: [id])
  transactions Transaction[]

  @@id([portfolioId, assetId])
}

model InvestStrategy {
  id      String   @id @default(uuid())
  title   String
  tickers String[]

  user   User?  @relation(fields: [userId], references: [id])
  userId String
}

enum MixedAssetType {
  REAL_ESTATE
  APPS
}

model MixedAssets {
  id       String         @id @default(uuid())
  title    String
  type     MixedAssetType
  quantity Int
  price    Float
}

model Transaction {
  id             String          @id @default(uuid())
  portfolioId    String
  assetId        String
  type           TransactionType
  quantityChange Float
  pricePerUnit   Float
  date           DateTime

  // portfolio      Portfolio      @relation(fields: [portfolioId], references: [id])
  // asset          Asset          @relation(fields: [assetId], references: [id])
  portfolioAsset PortfolioAsset @relation(fields: [portfolioId, assetId], references: [portfolioId, assetId])

  @@index([id, portfolioId, assetId])
}

enum TransactionType {
  BUY
  SELL
}

enum CouponFrequency {
  ANNUAL
  SEMI_ANNUAL
  QUARTERLY
  MONTHLY
}

model Bond {
  id              String          @id @default(uuid())
  isin            String
  name            String
  faceValue       Float
  couponRate      Float
  couponFrequency CouponFrequency
  quantity        Float           @default(0)
  purchasePrice   Float           @default(0)
  purchaseDate    DateTime        @default(now())

  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  portfolioId String
}

